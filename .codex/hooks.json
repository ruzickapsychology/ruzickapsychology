{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.codex/hooks/format-after-apply-patch.mjs\"",
            "timeout": 120,
            "statusMessage": "Formatting patched files"
          }
        ]
      }
    ]
  }
}
