{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|Edit|Write|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/scripts/format-hook-files.mjs\"",
            "timeout": 120,
            "statusMessage": "Formatting and linting edited files"
          }
        ]
      }
    ]
  }
}
