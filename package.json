{
  "name": "ruzickapsychology",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prepare": "husky",
    "typecheck": "next typegen && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "css-types": "tcm src --pattern \"**/*.module.css\" --allowArbitraryExtensions --outDir .generated/css-types && prettier --write \".generated/css-types/**/*.module.d.css.ts\"",
    "check:generated": "node scripts/check-generated-clean.mjs",
    "components:validate": "node scripts/validate-component-structure.mjs",
    "typegen": "sanity schema extract --enforce-required-fields && sanity typegen generate",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "playwright:install": "playwright install --with-deps chromium",
    "verify:quick": "npm run components:validate && npm run lint && npm run typecheck && npm run test",
    "verify": "npm run css-types && npm run typegen && npm run check:generated && npm run components:validate && npm run format:check && npm run lint && npm run typecheck && npm run sanity:validate-content && npm run test && npm run build",
    "verify:ci": "npm run verify && npm run playwright:install && npm run test:e2e",
    "verify:release": "npm run verify:ci && npm run lhci",
    "lhci": "lhci autorun",
    "analyze": "ANALYZE=true next build",
    "sanity:seed": "sanity exec scripts/seed-sanity.ts --with-user-token",
    "sanity:validate-content": "sanity exec scripts/validate-sanity-content.ts",
    "sanity:repair-keys": "sanity exec scripts/repair-sanity-array-keys.ts --with-user-token"
  },
  "dependencies": {
    "@portabletext/react": "^6.2.0",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.31.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "16.2.9",
    "next-sanity": "^13.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanity": "^5.31.1",
    "schema-dts": "^2.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.61.1",
    "@portabletext/markdown": "^1.4.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.35.2",
    "svgo": "^4.0.1",
    "tailwindcss": "^4",
    "typed-css-modules": "^0.9.1",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,css,md,mdx,yml,yaml}": "prettier --write --ignore-unknown",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "eslint --fix",
    "src/**/*.module.css": "bash -c 'npm run css-types'"
  }
}
